# .env.example — variable NAMES and descriptions only. Never put real values here.
# Copy to .env (git-ignored) and fill locally. The OS references these by name.
# The concrete set of variables is defined per project by the environment plan.

# --- Optional MCP / integration references (only if the project selects them) ---
# GITHUB_TOKEN=            # GitHub MCP + gh CLI (repo/PR operations)
# DATABASE_URL=            # Primary database connection string (read-only MCP tools)
# FIGMA_TOKEN=             # Design system / Figma MCP (read-only)
# SENTRY_AUTH_TOKEN=       # Monitoring MCP (read-only)

# --- Project variables (added by the environment plan; names only) ---
# APP_ENV=local            # local | test | development | staging | production
# APP_PORT=3000
# SESSION_SECRET=          # referenced by name only; provisioned via secret store
