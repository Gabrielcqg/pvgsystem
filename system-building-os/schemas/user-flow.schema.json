{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^FLOW-[0-9]{3,}$"
    },
    "actor": {
      "type": "string"
    },
    "trigger": {
      "type": "string"
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "system_responses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_state": {
      "type": "string"
    },
    "alternative_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cancellation_behavior": {
      "type": "string"
    },
    "recovery_behavior": {
      "type": "string"
    },
    "data_created_or_changed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audit_events": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "id",
    "actor",
    "trigger",
    "steps",
    "success_state",
    "acceptance_criteria"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User Flow / Journey",
  "$id": "user-flow.schema.json"
}
