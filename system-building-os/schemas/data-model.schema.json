{
  "type": "object",
  "properties": {
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^DB-[0-9]{3,}$"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "nullable": {
                  "type": "boolean"
                },
                "unique": {
                  "type": "boolean"
                },
                "description": {
                  "type": "string"
                },
                "classification": {
                  "type": "string",
                  "enum": [
                    "public",
                    "internal",
                    "personal",
                    "sensitive",
                    "secret"
                  ]
                }
              },
              "required": [
                "name",
                "type"
              ],
              "additionalProperties": false
            },
            "minItems": 1
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "indexes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "soft_delete": {
            "type": "boolean"
          },
          "audit_fields": {
            "type": "boolean"
          },
          "retention": {
            "type": "string"
          },
          "personal_data": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "name",
          "fields"
        ],
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "required": [
    "entities"
  ],
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data Model",
  "$id": "data-model.schema.json"
}
