{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ACTOR-[0-9]{3,}$"
    },
    "description": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "restrictions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entry_point": {
      "type": "string"
    },
    "frequency_of_use": {
      "type": "string"
    },
    "data_ownership": {
      "type": "string"
    },
    "trust_level": {
      "type": "string",
      "enum": [
        "anonymous",
        "authenticated",
        "privileged",
        "admin",
        "system",
        "service"
      ]
    }
  },
  "required": [
    "id",
    "description",
    "objective",
    "trust_level"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Actor",
  "$id": "actor.schema.json"
}
