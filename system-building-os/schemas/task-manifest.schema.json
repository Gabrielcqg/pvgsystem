{
  "type": "object",
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TASK-[0-9]{3,}$"
          },
          "title": {
            "type": "string"
          },
          "objective": {
            "type": "string"
          },
          "phase": {
            "type": "string"
          },
          "requirements": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z]+-[0-9]{3,}$"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^TASK-[0-9]{3,}$"
            }
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "files_to_create": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "files_to_modify": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "files_not_to_modify": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "assigned_agent": {
            "type": "string"
          },
          "required_skills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "optional_skills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_mcp_tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "validation_commands": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^AC-[0-9]{3,}$"
            }
          },
          "rollback": {
            "type": "string"
          },
          "stop_conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "estimated_complexity": {
            "type": "string",
            "enum": [
              "xs",
              "s",
              "m",
              "l",
              "xl"
            ]
          },
          "parallelization_group": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "objective",
          "requirements",
          "assigned_agent",
          "acceptance_criteria",
          "validation_commands"
        ],
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "required": [
    "tasks"
  ],
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task Manifest",
  "$id": "task-manifest.schema.json"
}
