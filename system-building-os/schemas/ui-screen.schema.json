{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^UI-[0-9]{3,}$"
    },
    "purpose": {
      "type": "string"
    },
    "permitted_users": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "route": {
      "type": "string"
    },
    "layout_regions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "information_hierarchy": {
      "type": "string"
    },
    "primary_action": {
      "type": "string"
    },
    "secondary_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "states": {
      "type": "object",
      "properties": {
        "default": {
          "type": "string"
        },
        "loading": {
          "type": "string"
        },
        "empty": {
          "type": "string"
        },
        "error": {
          "type": "string"
        },
        "success": {
          "type": "string"
        },
        "disabled": {
          "type": "string"
        },
        "partial_data": {
          "type": "string"
        }
      },
      "required": [
        "default",
        "loading",
        "empty",
        "error"
      ]
    },
    "responsive_behavior": {
      "type": "string"
    },
    "keyboard_behavior": {
      "type": "string"
    },
    "accessibility_behavior": {
      "type": "string"
    },
    "animation_behavior": {
      "type": "string"
    },
    "navigation_behavior": {
      "type": "string"
    },
    "persistence_behavior": {
      "type": "string"
    },
    "analytics_events": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "id",
    "purpose",
    "route",
    "primary_action",
    "states",
    "acceptance_criteria"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UI Screen / Page",
  "$id": "ui-screen.schema.json"
}
