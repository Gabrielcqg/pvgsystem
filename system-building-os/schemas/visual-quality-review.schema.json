{
  "type": "object",
  "properties": {
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "dimension": {
            "type": "string",
            "enum": [
              "product_communication",
              "information_architecture",
              "creativity",
              "usability",
              "responsiveness",
              "visual_quality",
              "state_completeness",
              "reference_compliance"
            ]
          },
          "question": {
            "type": "string"
          },
          "verdict": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail"
            ]
          },
          "evidence": {
            "type": "string"
          },
          "finding": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "dimension",
          "verdict"
        ],
        "additionalProperties": false
      },
      "minItems": 1
    },
    "overall_verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "gate": {
      "type": "string",
      "const": "frontend_experience_review_passed"
    },
    "screens_reviewed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "checks",
    "overall_verdict"
  ],
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Visual Quality Review",
  "$id": "visual-quality-review.schema.json"
}
