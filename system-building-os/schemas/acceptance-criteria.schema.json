{
  "type": "object",
  "properties": {
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-[0-9]{3,}$"
          },
          "requirement": {
            "type": "string",
            "pattern": "^[A-Z]+-[0-9]{3,}$"
          },
          "setup": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "expected_result": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "verification": {
            "type": "string",
            "enum": [
              "automated",
              "manual",
              "hybrid"
            ]
          },
          "test_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^TEST-[0-9]{3,}$"
            }
          }
        },
        "required": [
          "id",
          "requirement",
          "action",
          "expected_result",
          "verification"
        ],
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "required": [
    "criteria"
  ],
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Acceptance Criteria",
  "$id": "acceptance-criteria.schema.json"
}
